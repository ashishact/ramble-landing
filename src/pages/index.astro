---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main>
    <!-- Hero Section - Minimal Design -->
    <section class="hero-section">
      <div class="hero-container">
        <!-- Dot Matrix Visual -->
        <div class="visual-matrix">
          {Array.from({ length: 144 }).map(() => (
            <div class="dot"></div>
          ))}
        </div>

        <h1 class="hero-title">Ramble</h1>
        <p class="hero-tagline">Type with your voice</p>

        <a href="https://ramble-cdn.brokenatom.io/macos/releases/Ramble-1.8.dmg" class="download-btn">
          Download for macOS
        </a>

        <div class="meta">
          <span class="meta-tag">v1.8</span>
          <span class="meta-tag">Apple Silicon</span>
          <span class="meta-tag">Free</span>
        </div>
      </div>
    </section>

    <!-- Value Props -->
    <section class="py-24 px-6 bg-white">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-3 gap-8">
          <div class="p-8 bg-[#F2F0EB]/50 rounded-2xl border border-stone-200/50">
            <div class="w-12 h-12 flex items-center justify-center bg-stone-900 rounded-xl mb-5">
              <svg class="w-6 h-6 text-[#F2F0EB]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-3 text-stone-900">Private</h3>
            <p class="text-stone-500 leading-relaxed">
              Your voice never leaves your Mac. All transcription happens locally using Whisper AI.
            </p>
          </div>

          <div class="p-8 bg-[#F2F0EB]/50 rounded-2xl border border-stone-200/50">
            <div class="w-12 h-12 flex items-center justify-center bg-stone-900 rounded-xl mb-5">
              <svg class="w-6 h-6 text-[#F2F0EB]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-3 text-stone-900">Fast</h3>
            <p class="text-stone-500 leading-relaxed">
              Optimized for Apple Silicon. Your words appear instantly when you stop speaking.
            </p>
          </div>

          <div class="p-8 bg-[#F2F0EB]/50 rounded-2xl border border-stone-200/50">
            <div class="w-12 h-12 flex items-center justify-center bg-stone-900 rounded-xl mb-5">
              <svg class="w-6 h-6 text-[#F2F0EB]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"/>
                <path d="M8 12l2 2 4-4"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-3 text-stone-900">Simple</h3>
            <p class="text-stone-500 leading-relaxed">
              Tap right ⌘, speak, done. Text appears right where you're typing.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="py-24 px-6 bg-[#F2F0EB]">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-medium mb-16 text-stone-900 tracking-tight">How it works</h2>
        <div class="flex flex-col md:flex-row items-center justify-center gap-6 md:gap-4">
          <div class="flex flex-col items-center gap-4 p-8 bg-white rounded-2xl border border-stone-200/50 shadow-sm w-full md:w-auto md:min-w-[200px]">
            <div class="w-10 h-10 flex items-center justify-center bg-stone-900 rounded-full font-medium text-[#F2F0EB]">1</div>
            <div>
              <h4 class="font-semibold mb-1 text-stone-900">Tap right ⌘</h4>
              <p class="text-sm text-stone-400">From any app</p>
            </div>
          </div>

          <div class="text-2xl text-stone-300 rotate-90 md:rotate-0">→</div>

          <div class="flex flex-col items-center gap-4 p-8 bg-white rounded-2xl border border-stone-200/50 shadow-sm w-full md:w-auto md:min-w-[200px]">
            <div class="w-10 h-10 flex items-center justify-center bg-stone-900 rounded-full font-medium text-[#F2F0EB]">2</div>
            <div>
              <h4 class="font-semibold mb-1 text-stone-900">Speak naturally</h4>
              <p class="text-sm text-stone-400">At your normal pace</p>
            </div>
          </div>

          <div class="text-2xl text-stone-300 rotate-90 md:rotate-0">→</div>

          <div class="flex flex-col items-center gap-4 p-8 bg-white rounded-2xl border border-stone-200/50 shadow-sm w-full md:w-auto md:min-w-[200px]">
            <div class="w-10 h-10 flex items-center justify-center bg-stone-900 rounded-full font-medium text-[#F2F0EB]">3</div>
            <div>
              <h4 class="font-semibold mb-1 text-stone-900">Text appears</h4>
              <p class="text-sm text-stone-400">Instantly, where you need it</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Download CTA -->
    <section id="download" class="py-32 px-6 bg-white">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-medium mb-4 text-stone-900 tracking-tight">Ready to ramble?</h2>
        <p class="text-xl text-stone-500 mb-10">Start typing with your voice today.</p>
        <a href="https://ramble-cdn.brokenatom.io/macos/releases/Ramble-1.8.dmg" class="inline-flex items-center justify-center bg-stone-900 text-[#F2F0EB] px-10 py-5 rounded-xl font-medium text-lg hover:-translate-y-0.5 transition-all shadow-lg hover:shadow-xl">
          Download for macOS
        </a>
        <p class="text-sm text-stone-400 mt-5">Requires macOS 14 Sonoma or later</p>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-10 px-6 border-t border-stone-200 bg-[#F2F0EB]">
      <div class="max-w-6xl mx-auto text-center">
        <p class="text-sm text-stone-500">Built for people who think faster than they type.</p>
      </div>
    </footer>
  </main>
</Layout>

<style>
  /* Hero Section */
  .hero-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #F2F0EB;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");
    overflow: hidden;
  }

  .hero-container {
    text-align: center;
    max-width: 600px;
    padding: 2rem;
    position: relative;
    z-index: 10;
  }

  /* Dot Matrix Visual */
  .visual-matrix {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 8px;
    width: 200px;
    height: 240px;
    margin: 0 auto 3rem auto;
    mask-image: radial-gradient(circle, black 40%, transparent 70%);
    -webkit-mask-image: radial-gradient(circle, black 40%, transparent 70%);
  }

  .dot {
    width: 6px;
    height: 6px;
    background-color: #0F0F0F;
    border-radius: 50%;
    animation: breathe 4s infinite ease-in-out;
    opacity: 0.2;
  }

  .dot:nth-child(2n) { opacity: 0.8; animation-delay: 0.2s; }
  .dot:nth-child(3n) { opacity: 0.5; animation-delay: 0.5s; }
  .dot:nth-child(5n) { opacity: 1; animation-delay: 1s; transform: scale(1.2); }
  .dot:nth-child(7n) { opacity: 0; }
  .dot:nth-child(11n) { opacity: 0.9; animation-delay: 0.8s; }
  .dot:nth-child(13n) { opacity: 0.3; animation-delay: 1.2s; }

  @keyframes breathe {
    0%, 100% { transform: scale(1); opacity: 0.4; }
    50% { transform: scale(1.3); opacity: 0.9; }
  }

  /* Typography */
  .hero-title {
    font-size: 4.5rem;
    font-weight: 500;
    letter-spacing: -0.04em;
    margin: 0;
    line-height: 1;
    color: #0F0F0F;
  }

  .hero-tagline {
    font-size: 1.25rem;
    color: #666;
    margin: 1rem 0 3rem 0;
    letter-spacing: -0.01em;
  }

  /* Download Button */
  .download-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #0F0F0F;
    color: #F2F0EB;
    text-decoration: none;
    padding: 18px 42px;
    border-radius: 12px;
    font-weight: 500;
    font-size: 1.1rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .download-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.2);
  }

  .download-btn:active {
    transform: translateY(0);
  }

  /* Meta Tags */
  .meta {
    margin-top: 1.5rem;
    font-size: 0.8rem;
    color: #666;
  }

  .meta-tag {
    display: inline-block;
    background: rgba(0,0,0,0.05);
    padding: 4px 10px;
    border-radius: 6px;
    margin: 0 4px;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .hero-title {
      font-size: 3rem;
    }

    .visual-matrix {
      width: 160px;
      height: 192px;
      gap: 6px;
    }

    .dot {
      width: 5px;
      height: 5px;
    }
  }
</style>

