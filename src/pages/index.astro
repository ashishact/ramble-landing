---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

const downloadUrl = "https://ramble-cdn.brokenatom.io/macos/releases/Ramble-1.16.0.dmg";
---

<Layout>
  <Nav />

  <!-- Hero -->
  <section class="pt-32 pb-0 px-6 bg-white">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="font-heading text-5xl md:text-[70px] leading-[1.05] tracking-[-3px]">
        Hands-free productivity.
      </h1>
      <p class="text-lg md:text-xl text-muted mt-6 max-w-xl mx-auto leading-relaxed">
        Just speak your mind and let Ramble handle the busywork,
        saving you hours to actually enjoy your day.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-10">
        <a href={downloadUrl} class="flex items-center gap-3 bg-dark text-white px-7 py-4 rounded-2xl font-medium hover:-translate-y-0.5 transition-all shadow-lg">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><path d="M12.15 6.9c-.95 0-2.41-1.08-3.96-1.04-2.04.03-3.91 1.18-4.96 3.01-2.12 3.68-.55 9.1 1.52 12.09 1.01 1.45 2.21 3.09 3.79 3.04 1.52-.07 2.09-.99 3.94-.99 1.83 0 2.35.99 3.96.95 1.64-.03 2.67-1.48 3.67-2.95 1.16-1.69 1.64-3.33 1.66-3.42-.04-.01-3.18-1.22-3.22-4.86-.04-3.04 2.47-4.49 2.59-4.56-1.43-2.09-3.62-2.32-4.39-2.38-2-.16-3.67 1.09-4.6 1.09zM15.53 3.83c.84-1.01 1.4-2.43 1.25-3.83-1.21.05-2.66.8-3.53 1.82-.78.9-1.46 2.34-1.28 3.71 1.34.1 2.72-.7 3.56-1.7" fill="white"/></svg>
          Download for Mac
        </a>
        <a href="#" class="flex items-center gap-3 border border-dark/20 text-dark px-7 py-4 rounded-2xl font-medium hover:bg-dark hover:text-white transition-all">
          <svg class="w-5 h-5" viewBox="0 0 22 22" fill="none"><path d="M.46 0h9.62s.46 0 .46.46v9.62s0 .46-.46.46H.46S0 10.54 0 10.08V.46S0 0 .46 0z" fill="currentColor"/><path d="M.46 11.46h9.62s.46 0 .46.46v9.62s0 .46-.46.46H.46S0 22 0 21.54v-9.62s0-.46.46-.46z" fill="currentColor"/><path d="M11.92 11.46h9.62s.46 0 .46.46v9.62s0 .46-.46.46h-9.62s-.46 0-.46-.46v-9.62s0-.46.46-.46z" fill="currentColor"/><path d="M11.92 0h9.62s.46 0 .46.46v9.62s0 .46-.46.46h-9.62s-.46 0-.46-.46V.46s0-.46.46-.46z" fill="currentColor"/></svg>
          Join Windows waitlist
        </a>
      </div>
    </div>
  </section>

  <!-- Hero Video (full-width) -->
  <section class="relative mt-16">
    <video autoplay muted loop playsinline class="w-full">
      <source src="/assets/hero-video.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 flex items-center justify-center">
      <button class="flex items-center gap-3 bg-white/30 backdrop-blur-sm text-white px-6 py-3 rounded-xl font-medium hover:bg-white/50 transition-all">
        <svg class="w-5 h-5" viewBox="0 0 18 21" fill="none"><path d="M18 10.39L0 20.78V0l18 10.39z" fill="white"/></svg>
        Watch video
      </button>
    </div>
  </section>

  <!-- Value Props -->
  <section id="features" class="py-24 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-heading text-4xl md:text-[52px] leading-[1.1] tracking-[-2px] max-w-3xl">
        Do work productively with your voice,<br />
        save hours of busywork,<br />
        and be more productive than ever.
      </h2>

      <!-- Feature Cards -->
      <div class="mt-16 space-y-6">
        <!-- Card 1: Full width -->
        <div class="relative rounded-3xl overflow-hidden bg-brown min-h-[400px]">
          <div class="absolute inset-0">
            <video autoplay muted loop playsinline class="w-full h-full object-cover">
              <source src="/assets/feature-1.mp4" type="video/mp4" />
            </video>
            <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/30 to-transparent"></div>
          </div>
          <div class="relative z-10 p-10 md:p-14 max-w-md">
            <h3 class="font-heading text-3xl md:text-[40px] leading-tight tracking-[-1px] text-white">
              Your instant ticket out of the weeds.
            </h3>
            <p class="text-white/80 mt-4 leading-relaxed">
              Ramble at any application & let it do the work and let your mind wander.
            </p>
          </div>
        </div>

        <!-- Cards 2 & 3: Side by side -->
        <div class="grid md:grid-cols-2 gap-6">
          <div class="relative rounded-3xl overflow-hidden bg-brown min-h-[380px]">
            <div class="absolute inset-0">
              <video autoplay muted loop playsinline class="w-full h-full object-cover">
                <source src="/assets/feature-2.mp4" type="video/mp4" />
              </video>
              <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/30 to-transparent"></div>
            </div>
            <div class="relative z-10 p-10 max-w-sm">
              <h3 class="font-heading text-3xl md:text-[40px] leading-tight tracking-[-1px] text-white">
                Put your keyboard on ooo.
              </h3>
              <p class="text-white/80 mt-4 leading-relaxed text-sm">
                Dictate perfect emails, draft documents or code your way out in Claude while you literally put your feet up.
              </p>
            </div>
          </div>

          <div class="relative rounded-3xl overflow-hidden bg-brown min-h-[380px]">
            <div class="absolute inset-0">
              <video autoplay muted loop playsinline class="w-full h-full object-cover">
                <source src="/assets/feature-3.mp4" type="video/mp4" />
              </video>
              <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/30 to-transparent"></div>
            </div>
            <div class="relative z-10 p-10 max-w-sm">
              <h3 class="font-heading text-3xl md:text-[40px] leading-tight tracking-[-1px] text-white">
                Delegate your digital itinerary.
              </h3>
              <p class="text-white/80 mt-4 leading-relaxed text-sm">
                Command your PC to navigate heavy-duty apps and execute complex tasks without lifting a finger.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-24 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-heading text-5xl md:text-6xl tracking-[-2px]">How it works</h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-12">
        <!-- Step 1 -->
        <div>
          <div class="relative rounded-2xl overflow-hidden aspect-[3/4] border border-black/5">
            <img src="/assets/step-1.png" alt="Download the app" class="w-full h-full object-cover" />
            <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 bg-black/30">
              <a href={downloadUrl} class="flex items-center gap-2 bg-dark/90 text-white text-xs font-medium px-4 py-2.5 rounded-lg backdrop-blur-sm">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none"><path d="M12.15 6.9c-.95 0-2.41-1.08-3.96-1.04-2.04.03-3.91 1.18-4.96 3.01-2.12 3.68-.55 9.1 1.52 12.09 1.01 1.45 2.21 3.09 3.79 3.04 1.52-.07 2.09-.99 3.94-.99 1.83 0 2.35.99 3.96.95 1.64-.03 2.67-1.48 3.67-2.95 1.16-1.69 1.64-3.33 1.66-3.42-.04-.01-3.18-1.22-3.22-4.86-.04-3.04 2.47-4.49 2.59-4.56-1.43-2.09-3.62-2.32-4.39-2.38-2-.16-3.67 1.09-4.6 1.09zM15.53 3.83c.84-1.01 1.4-2.43 1.25-3.83-1.21.05-2.66.8-3.53 1.82-.78.9-1.46 2.34-1.28 3.71 1.34.1 2.72-.7 3.56-1.7" fill="white"/></svg>
                Download for Mac
              </a>
              <a href="#" class="flex items-center gap-2 bg-dark/90 text-white text-xs font-medium px-4 py-2.5 rounded-lg backdrop-blur-sm">
                <svg class="w-3.5 h-3.5" viewBox="0 0 22 22" fill="none"><path d="M.46 0h9.62s.46 0 .46.46v9.62s0 .46-.46.46H.46S0 10.54 0 10.08V.46S0 0 .46 0z" fill="white"/><path d="M.46 11.46h9.62s.46 0 .46.46v9.62s0 .46-.46.46H.46S0 22 0 21.54v-9.62s0-.46.46-.46z" fill="white"/><path d="M11.92 11.46h9.62s.46 0 .46.46v9.62s0 .46-.46.46h-9.62s-.46 0-.46-.46v-9.62s0-.46.46-.46z" fill="white"/><path d="M11.92 0h9.62s.46 0 .46.46v9.62s0 .46-.46.46h-9.62s-.46 0-.46-.46V.46s0-.46.46-.46z" fill="white"/></svg>
                Join Windows waitlist
              </a>
            </div>
          </div>
          <p class="font-heading text-lg mt-4">Download the app</p>
        </div>

        <!-- Step 2 -->
        <div>
          <div class="rounded-2xl overflow-hidden aspect-[3/4] border border-black/5">
            <img src="/assets/step-2.png" alt="Press keyboard shortcut" class="w-full h-full object-cover" />
          </div>
          <p class="font-heading text-lg mt-4">Press keyboard shortcut on any tab to summon Ramble</p>
        </div>

        <!-- Step 3 -->
        <div>
          <div class="rounded-2xl overflow-hidden aspect-[3/4] border border-black/5">
            <img src="/assets/step-3.png" alt="Tell Ramble what you need" class="w-full h-full object-cover" />
          </div>
          <p class="font-heading text-lg mt-4">Tell Ramble what you need to accomplish</p>
        </div>

        <!-- Step 4 -->
        <div>
          <div class="rounded-2xl overflow-hidden aspect-[3/4] border border-black/5">
            <img src="/assets/step-4.png" alt="Sit back and relax" class="w-full h-full object-cover" />
          </div>
          <p class="font-heading text-lg mt-4">Sit back, enjoy your time while Ramble does the tasks for you.</p>
        </div>
      </div>

      <div class="flex justify-center mt-12">
        <a href={downloadUrl} class="flex items-center gap-3 bg-dark text-white px-7 py-4 rounded-2xl font-medium hover:-translate-y-0.5 transition-all shadow-lg">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><path d="M12.15 6.9c-.95 0-2.41-1.08-3.96-1.04-2.04.03-3.91 1.18-4.96 3.01-2.12 3.68-.55 9.1 1.52 12.09 1.01 1.45 2.21 3.09 3.79 3.04 1.52-.07 2.09-.99 3.94-.99 1.83 0 2.35.99 3.96.95 1.64-.03 2.67-1.48 3.67-2.95 1.16-1.69 1.64-3.33 1.66-3.42-.04-.01-3.18-1.22-3.22-4.86-.04-3.04 2.47-4.49 2.59-4.56-1.43-2.09-3.62-2.32-4.39-2.38-2-.16-3.67 1.09-4.6 1.09zM15.53 3.83c.84-1.01 1.4-2.43 1.25-3.83-1.21.05-2.66.8-3.53 1.82-.78.9-1.46 2.34-1.28 3.71 1.34.1 2.72-.7 3.56-1.7" fill="white"/></svg>
          Download for Mac
        </a>
      </div>
    </div>
  </section>

  <!-- Privacy -->
  <section id="privacy" class="py-24 px-6 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-heading text-5xl md:text-6xl tracking-[-2px]">Private by design.</h2>
        <p class="text-xl md:text-2xl text-muted mt-4">We sell software, not your data.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="p-8 rounded-2xl bg-cream-light/30 border border-black/5">
          <h3 class="font-heading text-2xl md:text-[30px] tracking-[-1px]">No Training</h3>
          <p class="text-muted mt-4 leading-relaxed">We have strict agreements with our AI partners. Your voice and data are never used to train their models.</p>
        </div>
        <div class="p-8 rounded-2xl bg-cream-light/30 border border-black/5">
          <h3 class="font-heading text-2xl md:text-[30px] tracking-[-1px]">Ephemeral Processing</h3>
          <p class="text-muted mt-4 leading-relaxed">Your requests are processed instantly and then discarded. We don't build a profile on you or store your request history.</p>
        </div>
        <div class="p-8 rounded-2xl bg-cream-light/30 border border-black/5">
          <h3 class="font-heading text-2xl md:text-[30px] tracking-[-1px]">Local First</h3>
          <p class="text-muted mt-4 leading-relaxed">Wherever possible, Ramble uses on-device intelligence to understand context before reaching out to the cloud.</p>
        </div>
      </div>

      <p class="text-center text-sm text-muted mt-8">
        Read more on our <a href="#" class="underline hover:text-dark">privacy page</a>
      </p>
    </div>
  </section>

  <FAQ />

  <!-- Mascot -->
  <section class="py-16 px-6 bg-white">
    <div class="max-w-md mx-auto">
      <img src="/assets/mascot.svg" alt="Ramble mascot" class="w-full" />
    </div>
  </section>

  <!-- CTA (contained, rounded) -->
  <section class="px-6 pb-16 bg-white">
    <div class="relative max-w-5xl mx-auto rounded-3xl overflow-hidden">
      <div class="absolute inset-0">
        <img src="/assets/campfire.png" alt="" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/20 to-black/10"></div>
      </div>
      <div class="relative z-10 py-24 px-6 text-center text-white">
        <h2 class="font-serif text-5xl md:text-6xl leading-tight">Ready to pack your bags?</h2>
        <p class="text-lg md:text-xl mt-4 text-white/80">Reclaim your time and start enjoying your workday again.</p>
        <a href={downloadUrl} class="inline-flex items-center gap-2 mt-10 bg-dark text-white text-lg font-medium px-8 py-4 rounded-2xl hover:-translate-y-0.5 transition-all shadow-lg">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><path d="M12.15 6.9c-.95 0-2.41-1.08-3.96-1.04-2.04.03-3.91 1.18-4.96 3.01-2.12 3.68-.55 9.1 1.52 12.09 1.01 1.45 2.21 3.09 3.79 3.04 1.52-.07 2.09-.99 3.94-.99 1.83 0 2.35.99 3.96.95 1.64-.03 2.67-1.48 3.67-2.95 1.16-1.69 1.64-3.33 1.66-3.42-.04-.01-3.18-1.22-3.22-4.86-.04-3.04 2.47-4.49 2.59-4.56-1.43-2.09-3.62-2.32-4.39-2.38-2-.16-3.67 1.09-4.6 1.09zM15.53 3.83c.84-1.01 1.4-2.43 1.25-3.83-1.21.05-2.66.8-3.53 1.82-.78.9-1.46 2.34-1.28 3.71 1.34.1 2.72-.7 3.56-1.7" fill="white"/></svg>
          Download for Mac
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
