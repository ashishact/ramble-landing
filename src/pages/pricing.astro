---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const starterFeatures = [
  "30min active command/day",
  "Limited voice commands",
  "Claude & ChatGPT-4o integration",
  "Access to limited future integrations",
];

const creatorFeatures = [
  "Unlimited access",
  "Unlimited voice commands",
  "Claude & ChatGPT-4o integration",
  "Access to all future OS integrations",
  "Priority support",
];
---

<Layout title="Pricing — Ramble" description="Choose the plan that's right for you. Start with a free tier or unlock unlimited access.">
  <Nav />

  <!-- Pricing Hero -->
  <section class="pt-40 pb-24 px-6 bg-white">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="font-heading text-5xl md:text-7xl leading-[1.05] tracking-tight">
        Start Rambling,<br />Start Living.
      </h1>
      <p class="text-lg md:text-xl text-muted mt-6">
        Choose the plan that's right for you.
      </p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="pb-24 px-6 bg-white">
    <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-6">
      <!-- Starter -->
      <div class="p-8 rounded-2xl border border-black/10 bg-white">
        <h3 class="text-2xl font-medium">Starter</h3>
        <div class="mt-4">
          <span class="text-3xl font-heading">Free</span>
        </div>
        <a href="#" class="block mt-6 text-center bg-dark text-white py-3 rounded-xl font-medium hover:-translate-y-0.5 transition-all">
          Start Rambling
        </a>
        <div class="mt-8">
          <p class="text-sm text-muted mb-4">Included in Starter</p>
          <ul class="space-y-3">
            {starterFeatures.map((f) => (
              <li class="flex items-start gap-3 text-[15px]">
                <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-green-500" viewBox="0 0 24 24" fill="none"><path clip-rule="evenodd" d="M12 21a9 9 0 100-18 9 9 0 000 18zm-.23-5.36l5-6-1.54-1.28-4.3 5.16-2.22-2.23-1.42 1.42 3 3 .77.77.71-.84z" fill="currentColor" fill-rule="evenodd"/></svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Creator -->
      <div class="relative p-8 rounded-2xl border border-black/10 bg-gradient-to-b from-[#0b2a60] to-[#1a1a2e] text-white overflow-hidden">
        <!-- Background illustration -->
        <img src="/assets/window-night.png" alt="" class="absolute inset-0 w-full h-full object-cover opacity-20 pointer-events-none" />
        <div class="relative z-10">
          <h3 class="text-2xl font-medium">Creator</h3>
          <div class="mt-4 flex items-baseline gap-3">
            <span class="text-3xl font-heading">&#8377;499/mo</span>
            <span class="text-xl line-through text-white/50">&#8377;1599/mo</span>
          </div>
          <a href="#" class="block mt-6 text-center bg-white text-dark py-3 rounded-xl font-medium hover:-translate-y-0.5 transition-all">
            Start 7-days free trial
          </a>
          <div class="mt-8">
            <p class="text-sm text-white/60 mb-4">Everything included in Starter and</p>
            <ul class="space-y-3">
              {creatorFeatures.map((f) => (
                <li class="flex items-start gap-3 text-[15px]">
                  <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-green-400" viewBox="0 0 24 24" fill="none"><path clip-rule="evenodd" d="M12 21a9 9 0 100-18 9 9 0 000 18zm-.23-5.36l5-6-1.54-1.28-4.3 5.16-2.22-2.23-1.42 1.42 3 3 .77.77.71-.84z" fill="currentColor" fill-rule="evenodd"/></svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQ />
  <CTA />
  <Footer />
</Layout>
