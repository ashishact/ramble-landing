        </a>
        <a href="#" class="text-dark hover:text-brown transition-colors" aria-label="LinkedIn">
          <svg class="w-5 h-5" viewBox="0 0 13 15" fill="currentColor"><path d="M9.5 14.5h3c.13 0 .26-.05.35-.15.1-.09.15-.22.15-.35V5.6c0-3.77-2.13-5.6-5.11-5.6-.59-.02-1.18.08-1.73.3-.55.22-1.04.55-1.45.98-.06.06-.13.1-.21.12-.08.02-.17.01-.24-.03-.08-.03-.14-.08-.18-.14-.05-.07-.07-.15-.07-.23 0-.13-.05-.26-.15-.35C3.76.56 3.63.5 3.5.5H.5c-.13 0-.26.05-.35.15C.05.74 0 .87 0 1v13c0 .13.05.26.15.36.09.09.22.14.35.14h3c.13 0 .26-.05.35-.15.1-.09.15-.22.15-.35V6.5c0-.66.26-1.3.73-1.77S5.84 4 6.5 4c.66 0 1.3.26 1.77.73S9 5.84 9 6.5V14c0 .13.05.26.15.36.09.09.22.14.35.14z"/></svg>
        </a>
      </div>

      <p class="text-sm text-muted">Ramble. All rights reserved. &copy; {new Date().getFullYear()}</p>
    </div>
  </div>
</footer>
