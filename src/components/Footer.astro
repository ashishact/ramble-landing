---
const downloadUrl = "https://ramble-cdn.brokenatom.io/macos/releases/Ramble-1.16.0.dmg";
---

<footer class="bg-white border-t border-black/5">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10">
      <!-- Product -->
      <div>
        <h4 class="font-serif text-2xl mb-4">Product</h4>
        <ul class="space-y-3 text-sm text-muted">
          <li><a href="/#features" class="hover:text-dark transition-colors">Features</a></li>
          <li><a href="/pricing" class="hover:text-dark transition-colors">Pricing</a></li>
          <li><a href="#faq" class="hover:text-dark transition-colors">FAQ</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="font-serif text-2xl mb-4">Resources</h4>
        <ul class="space-y-3 text-sm text-muted">
          <li><a href="#" class="hover:text-dark transition-colors">Support</a></li>
          <li><a href="#" class="hover:text-dark transition-colors">Discord</a></li>
          <li><a href="#" class="hover:text-dark transition-colors">Security</a></li>
          <li><a href="#" class="hover:text-dark transition-colors">Trust Center</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-serif text-2xl mb-4">Company</h4>
        <ul class="space-y-3 text-sm text-muted">
          <li><a href="#" class="hover:text-dark transition-colors">About us</a></li>
          <li><a href="#" class="hover:text-dark transition-colors">Privacy policy</a></li>
          <li><a href="#" class="hover:text-dark transition-colors">Terms and conditions</a></li>
        </ul>
      </div>

      <!-- Actions -->
      <div class="flex flex-col gap-3">
        <a href={downloadUrl} class="inline-flex items-center justify-center gap-2 bg-dark text-white text-sm font-medium px-5 py-3 rounded-xl hover:-translate-y-0.5 transition-all">
          Get desktop app
        </a>
        <a href="#" class="inline-flex items-center justify-center gap-2 border border-dark text-dark text-sm font-medium px-5 py-3 rounded-xl hover:bg-dark hover:text-white transition-all">
          Join Windows waitlist
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-black/5 flex flex-col md:flex-row items-center justify-between gap-4">
      <!-- Social icons -->
      <div class="flex items-center gap-4">
        <a href="#" class="text-dark hover:text-brown transition-colors" aria-label="X">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M14.23 10.16L22.98 0h-2.07l-7.6 8.82L7.25 0H.26l9.17 13.34L.26 24h2.07l8.02-9.32L16.75 24h6.99l-9.51-13.84zm-2.84 3.3l-.93-1.33L3.08 1.56h3.18l5.97 8.53.93 1.33 7.75 11.09h-3.18l-6.33-9.05z"/></svg>
        </a>
