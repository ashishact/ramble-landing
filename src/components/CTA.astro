---
const downloadUrl = "https://ramble-cdn.brokenatom.io/macos/releases/Ramble-1.16.0.dmg";
---

<section class="relative py-32 px-6 overflow-hidden">
  <!-- Campfire background -->
  <div class="absolute inset-0">
    <img src="/assets/campfire.png" alt="" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/30 to-black/10"></div>
  </div>

  <div class="relative z-10 max-w-3xl mx-auto text-center text-white">
    <h2 class="font-serif text-5xl md:text-6xl leading-tight">Ready to pack your bags?</h2>
    <p class="text-lg md:text-xl mt-4 text-white/80">Reclaim your time and start enjoying your workday again.</p>
    <a href={downloadUrl} class="inline-flex items-center gap-2 mt-10 bg-dark text-white text-lg font-medium px-8 py-4 rounded-xl hover:-translate-y-0.5 transition-all shadow-lg">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none"><path d="M12.15 6.9c-.95 0-2.41-1.08-3.96-1.04-2.04.03-3.91 1.18-4.96 3.01-2.12 3.68-.55 9.1 1.52 12.09 1.01 1.45 2.21 3.09 3.79 3.04 1.52-.07 2.09-.99 3.94-.99 1.83 0 2.35.99 3.96.95 1.64-.03 2.67-1.48 3.67-2.95 1.16-1.69 1.64-3.33 1.66-3.42-.04-.01-3.18-1.22-3.22-4.86-.04-3.04 2.47-4.49 2.59-4.56-1.43-2.09-3.62-2.32-4.39-2.38-2-.16-3.67 1.09-4.6 1.09zM15.53 3.83c.84-1.01 1.4-2.43 1.25-3.83-1.21.05-2.66.8-3.53 1.82-.78.9-1.46 2.34-1.28 3.71 1.34.1 2.72-.7 3.56-1.7" fill="white"/></svg>
      Download for Mac
    </a>
  </div>
</section>
